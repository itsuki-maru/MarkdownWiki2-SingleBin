{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkdownWiki2-SingleBin",
  "version": "2.1.3",
  "identifier": "com.itsuki.markdown-wiki2-single-bin",
  "build": {
    "frontendDist": "dist"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["res/icon.ico"],
    "windows": {
      "nsis": {
        "languages": ["Japanese"],
        "installerIcon": "res/icon.ico"
      },
      "wix": {
        "language": "ja-JP"
      }
    }
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  }
}
