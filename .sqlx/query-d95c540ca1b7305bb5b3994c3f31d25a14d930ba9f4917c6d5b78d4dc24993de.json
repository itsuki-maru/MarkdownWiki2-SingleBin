  "query": "SELECT\n                id,\n                user_id,\n                date,\n                title,\n                body,\n                update_at,\n                is_public,\n                is_edit_request\n            FROM wiki_model\n            WHERE (user_id = $1 OR is_public = true)\n            AND (title LIKE $2 ESCAPE '\\' OR body LIKE $2 ESCAPE '\\')\n            AND (title LIKE $3 ESCAPE '\\' OR body LIKE $3 ESCAPE '\\')\n            ORDER BY id DESC",
